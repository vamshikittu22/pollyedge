# ════════════════════════════════════
# POLLYEDGE v2.0 — ENVIRONMENT CONFIG
# Copy to .env and fill in your values
# NEVER commit .env to GitHub
# ════════════════════════════════════

# Wallet (from MetaMask export)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
FUNDER=0xYOUR_POLYMARKET_PROXY_WALLET_ADDRESS
CHAIN_ID=137

# Capital ($10 start — DRY_RUN=true for 7 days minimum!)
STARTING_BALANCE=10
DRY_RUN=true

# Human approval — EVERY trade needs your Telegram OK
REQUIRE_APPROVAL=true
APPROVAL_TIMEOUT_SEC=120

# Safety rules (tuned for $10 capital)
MAX_TRADE_PCT=0.50
DAILY_LOSS_CAP=0.30
MAX_POSITIONS=1
MIN_EDGE=0.08
PROFIT_TARGET=0.30
STOP_LOSS=0.10
EDGE_THRESHOLD=0.03

# Agent scan config
NUM_AGENTS=5
AGENT_SCAN_INTERVAL=15

# Telegram alerts + approval
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CHAT_ID=YOUR_PERSONAL_CHAT_ID

# Data sources — Daloopa (primary)
DALOOPA_API_KEY=YOUR_DALOOPA_KEY

# Data sources — Free tier
NEWSAPI_KEY=get_free_at_newsapi.org
ALPHA_VANTAGE_KEY=get_free_at_alphavantage.co
COINGECKO_API_KEY=
